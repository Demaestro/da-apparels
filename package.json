{
  "name": "da-apparels",
  "version": "1.0.0",
  "private": true,
  "description": "DA Apparels — Luxury Fashion Platform",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @da-apparels/database generate",
    "db:migrate": "pnpm --filter @da-apparels/database migrate:dev",
    "db:studio": "pnpm --filter @da-apparels/database studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
