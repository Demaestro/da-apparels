# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://da_user:da_password@localhost:5432/da_apparels"
SHADOW_DATABASE_URL="postgresql://da_user:da_password@localhost:5432/da_apparels_shadow"

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-256-bit-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-another-256-bit-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Auth0 (optional — use instead of JWT if preferred)
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID="your-client-id"
AUTH0_CLIENT_SECRET="your-client-secret"
AUTH0_AUDIENCE="https://api.da-apparels.com"

# ─── Encryption ─────────────────────────────────────────────────────────────────
# AES-256 key — must be exactly 32 bytes (256 bits), hex-encoded
ENCRYPTION_KEY="replace-with-64-hex-chars-0000000000000000000000000000000000000000"

# ─── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── App URLs ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── BullMQ / Worker ────────────────────────────────────────────────────────────
BULL_REDIS_URL="redis://localhost:6379"

# ─── Email (Resend or SendGrid) ─────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@da-apparels.com"

# ─── Environment ────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
