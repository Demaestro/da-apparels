# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://da_user:da_password@localhost:5432/da_apparels"
SHADOW_DATABASE_URL="postgresql://da_user:da_password@localhost:5432/da_apparels_shadow"

# ── Redis (BullMQ job queue + cache) ──────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
BULL_REDIS_URL="redis://localhost:6379"

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-64-char-random-hex-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-different-64-char-random-hex-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Encryption (measurements vault) ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-64-hex-chars"

# ── URLs ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cloudinary (product image CDN) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Paystack (online payment) ──────────────────────────────────────────────────
# Leave empty or use a placeholder to fall back to manual bank transfer mode.
PAYSTACK_SECRET_KEY=""

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Leave empty in development — emails are logged to the console.
RESEND_API_KEY=""
EMAIL_FROM="noreply@example.com"
SUPPORT_EMAIL="support@example.com"
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

# ── Manual bank-transfer payment details ──────────────────────────────────────
# Required when PAYSTACK_SECRET_KEY is empty.
# NEVER commit real account details — set these in your hosting provider's env dashboard.
MANUAL_PAYMENT_BANK_NAME="YOUR BANK NAME"
MANUAL_PAYMENT_ACCOUNT_NAME="YOUR ACCOUNT NAME"
MANUAL_PAYMENT_ACCOUNT_NUMBER="YOUR ACCOUNT NUMBER"

# ── Support WhatsApp ──────────────────────────────────────────────────────────
# E.164 format without the leading +, e.g. 2348000000000
SUPPORT_WHATSAPP=""

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
